# Base de dados
DATABASE_URL="postgresql://crmpexe:crmpexe@localhost:5432/crmpexe?schema=public"
SHADOW_DATABASE_URL="postgresql://crmpexe:crmpexe@localhost:5432/crmpexe_shadow?schema=public"

# CORS (origens permitidas, separadas por vírgula; dev: porta do Vite 8081)
CORS_ORIGIN="http://localhost:8081,http://localhost:3000,http://127.0.0.1:8081"

# JWT
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_IMPERSONATION_EXPIRES_IN="15m"

# SMTP (e-mail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="CrmPexe <seu-email@gmail.com>"

# OTP e integrações (chave base64 para criptografia de contas de integração)
OTP_TTL_MS=600000
OTP_DAILY_LIMIT=20
INTEGRATION_ENCRYPTION_KEY=""

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="seu-access-token"
MERCADOPAGO_PUBLIC_KEY="sua-public-key"
MERCADOPAGO_WEBHOOK_SECRET="seu-webhook-secret"

# Rate limit
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=20
WEBHOOK_RATE_LIMIT_WINDOW_MS=300000
WEBHOOK_RATE_LIMIT_MAX=120

# Login (bloqueio após tentativas)
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MS=900000
LOGIN_BLOCK_MS=900000

# Webhooks (assinaturas)
WHATSAPP_WEBHOOK_SECRET="seu-webhook-secret-whatsapp"
WHATSAPP_WEBHOOK_SIGNATURE_HEADER="x-whatsapp-signature"
EMAIL_WEBHOOK_SIGNATURE_HEADER="x-email-signature"

# OpenAI (opcional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Redis (rate limit, filas; opcional em dev)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
# REDIS_URL="redis://127.0.0.1:6379"
# REDIS_PASSWORD=""

# n8n
N8N_BASE_URL="http://localhost:5678"
N8N_LOCAL_BASE_URL="http://localhost:5678"
N8N_INTERNAL_BASE_URL="http://n8n:5678"
N8N_API_TOKEN=""
N8N_DELETE_PREVIOUS_WORKFLOW_ON_ACTIVATE="false"
